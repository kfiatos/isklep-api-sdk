{
    "name": "isklep/api-sdk",
    "description": "Abstract PHP SDK for ISklep API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/guzzle": "^7.9",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "ISklep\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ISklep\\Api\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
